<RoleScreen>
    name: "role"
    md_bg_color: 0.12, 0.12, 0.14, 1

    MDBoxLayout:
        orientation: "vertical"
        spacing: "24dp"
        padding: "24dp"

        MDLabel:
            text: "Choose Your Role"
            halign: "center"
            font_style: "H4"
            bold: True
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1
            size_hint_y: 0.3

        MDLabel:
            text: "Select how this device will be used"
            halign: "center"
            font_style: "Body1"
            theme_text_color: "Custom"
            text_color: 0.6, 0.6, 0.6, 1
            size_hint_y: 0.1

        MDBoxLayout:
            orientation: "horizontal"
            spacing: "16dp"
            size_hint_y: 0.5
            pos_hint: {"center_x": 0.5}

            MDRectangleFlatButton:
                text: "I am Mobile A\n(Use Remote Storage)"
                size_hint: 0.45, 0.6
                pos_hint: {"center_x": 0.5, "center_y": 0.5}
                font_size: "14sp"
                line_color: 0.3, 0.7, 0.3, 1
                text_color: 0.3, 0.7, 0.3, 1
                on_release: root.select_role_a()

            MDRectangleFlatButton:
                text: "I am Mobile B\n(Provide Storage)"
                size_hint: 0.45, 0.6
                pos_hint: {"center_x": 0.5, "center_y": 0.5}
                font_size: "14sp"
                line_color: 0.3, 0.5, 0.9, 1
                text_color: 0.3, 0.5, 0.9, 1
                on_release: root.select_role_b()
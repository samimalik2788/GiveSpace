<SplashScreen>
    md_bg_color: 0.12, 0.12, 0.14, 1  # Dark background

    MDBoxLayout:
        orientation: "vertical"
        size_hint: 1, 1
        pos_hint: {"center_x": 0.5, "center_y": 0.5}

        MDLabel:
            text: "M.S.U"
            halign: "center"
            valign: "center"
            font_style: "H2"
            font_size: "72sp"
            bold: True
            theme_text_color: "Custom"
            text_color: 0.3, 0.7, 0.3, 1  # Green tint
            pos_hint: {"center_x": 0.5, "center_y": 0.5}

        MDLabel:
            text: "Give Space"
            halign: "center"
            valign: "center"
            font_style: "Subtitle1"
            theme_text_color: "Custom"
            text_color: 0.6, 0.6, 0.6, 1
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            padding_y: "8dp"